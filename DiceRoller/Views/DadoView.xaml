<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DiceRoller.Views.DadoView"
             Title="DadoView">
    <VerticalStackLayout>
        <Label 
            x:Name="ValorSorteado"
            Text="{Binding LadoSorteado}"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />
        <Button
            Text="Sortear"
            Command="{Binding RolarUmDadoCommand}"/>
    </VerticalStackLayout>
</ContentPage>